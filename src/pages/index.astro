---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const IMG = 'https://images.unsplash.com/';
const hero     = IMG + 'photo-1515562141207-7a88fb7ce338?auto=format&fit=crop&w=900&q=80';
const diamond  = IMG + 'photo-1573408301185-9519b33b77c7?auto=format&fit=crop&w=800&q=80';
const gold     = IMG + 'photo-1599643478518-a784e5dc4c8f?auto=format&fit=crop&w=800&q=80';
const story    = IMG + 'photo-1605100804763-247f67b3557e?auto=format&fit=crop&w=700&q=80';
---

<BaseLayout
  title="Home"
  description="Samir Akkawi Jewelry — Fine gold and diamond jewelry crafted to last a lifetime. Boutique store in Amman, Jordan, since the early 1990s."
  transparentNav={true}
>

  <!-- HERO -->
  <section class="hero" aria-label="Welcome">
    <div class="hero-text">
      <div class="hero-text-inner">
        <span class="section-eyebrow"
          data-en="Est. Early 1990s · Amman, Jordan"
          data-ar="تأسس مطلع التسعينيات · عمّان، الأردن">Est. Early 1990s · Amman, Jordan</span>
        <h1 class="hero-title"
          data-en="Jewelry You'll Always Want to Wear"
          data-ar="مجوهرات ستريد ارتداءها دائماً">
          Jewelry You'll<br />
          <em>Always Want<br />to Wear</em>
        </h1>
        <div class="gold-rule"></div>
        <p class="hero-sub"
          data-en="Fine gold and diamond pieces crafted to last a lifetime — unique, classic, and made with care for Jordan's most special moments."
          data-ar="قطع من الذهب والألماس الراقية تُصنع لتدوم مدى الحياة — فريدة، كلاسيكية، ومصنوعة بعناية لأجمل المناسبات الأردنية.">
          Fine gold and diamond pieces crafted to last a lifetime —
          unique, classic, and made with care for Jordan's most special moments.
        </p>
        <div class="hero-actions">
          <a href={`${base}collections`} class="btn btn-primary">
            <span data-en="Explore Collections" data-ar="استكشف المجموعات">Explore Collections</span>
          </a>
          <a href={`${base}contact`} class="btn btn-ghost">
            <span data-en="Visit the Store" data-ar="زر المتجر">Visit the Store</span>
          </a>
        </div>
      </div>
    </div>

    <div class="hero-image" aria-hidden="true">
      <img
        src={hero}
        alt="Fine jewelry by Samir Akkawi"
        width="900"
        height="1200"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- BRAND STORY -->
  <section class="story" id="story" aria-label="Our story">
    <div class="story-inner container">

      <div class="story-image reveal">
        <img
          src={story}
          alt="Fine diamond jewelry craftsmanship"
          width="700"
          height="840"
          loading="lazy"
        />
      </div>

      <div class="story-text reveal">
        <span class="section-eyebrow" data-en="Our Story" data-ar="قصتنا">Our Story</span>
        <h2 class="section-title"
          data-en="The Way It All Began"
          data-ar="كيف بدأت قصتنا">The Way It<br />All Began</h2>
        <div class="gold-rule"></div>
        <p data-en="Samir Akkawi Jewelry opened its doors in Amman in the early 1990s with a single belief: that fine jewelry should be both unique and timeless — pieces you choose for the milestones that matter most, and wear for the rest of your life."
           data-ar="فتحت محلات سمير عكاوي للمجوهرات أبوابها في عمّان مطلع التسعينيات بإيمان راسخ: أن المجوهرات الراقية يجب أن تكون فريدة وخالدة في آنٍ واحد — قطع تختارها في أهم محطات حياتك، وترتديها طيلة عمرك.">
          Samir Akkawi Jewelry opened its doors in Amman in the early 1990s with a
          single belief: that fine jewelry should be both unique and timeless — pieces
          you choose for the milestones that matter most, and wear for the rest of your life.
        </p>
        <p data-en="Over thirty years, that belief has earned us the trust of families across Jordan. We work with certified Belgian diamonds and 18-karat gold, and we stand behind every piece we sell — with complimentary after-sales care and free appraisals for the lifetime of your jewelry."
           data-ar="على مدى أكثر من ثلاثين عاماً، أكسبنا هذا الإيمان ثقة الأسر في كافة أنحاء الأردن. نعمل مع الألماس البلجيكي المعتمد والذهب عيار 18، ونقف خلف كل قطعة نبيعها — مع خدمة ما بعد البيع المجانية والتقييم المجاني مدى الحياة.">
          Over thirty years, that belief has earned us the trust of families across Jordan.
          We work with certified Belgian diamonds and 18-karat gold, and we stand behind
          every piece we sell — with complimentary after-sales care and free appraisals
          for the lifetime of your jewelry.
        </p>
        <a href={`${base}about`} class="text-link">
          <span data-en="Our full story" data-ar="قصتنا الكاملة">Our full story</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

    </div>
  </section>

  <!-- COLLECTIONS PREVIEW -->
  <section class="collections-preview" aria-label="Collections">
    <div class="container">
      <div class="collections-heading reveal">
        <span class="section-eyebrow" data-en="Curated for You" data-ar="مختار لك">Curated for You</span>
        <h2 class="section-title" data-en="Our Collections" data-ar="مجموعاتنا">Our Collections</h2>
      </div>
    </div>

    <div class="collections-grid">

      <a href={`${base}collections/diamond`} class="collection-card reveal">
        <div class="collection-card-img">
          <img
            src={diamond}
            alt="Diamond Collection — rings, necklaces, bracelets and more"
            width="800"
            height="960"
            loading="lazy"
          />
          <div class="collection-card-overlay"></div>
        </div>
        <div class="collection-card-body">
          <h3 data-en="Diamond Collection" data-ar="مجموعة الماس">Diamond Collection</h3>
          <p data-en="Certified Belgian diamonds set in white and yellow gold — rings, necklaces, bracelets, earrings, and rare finds."
             data-ar="الماس بلجيكي معتمد في إطارات من الذهب الأبيض والأصفر — خواتم وقلائد وأساور وأقراط وتشكيلات نادرة.">
            Certified Belgian diamonds set in white and yellow gold —
            rings, necklaces, bracelets, earrings, and rare finds.
          </p>
          <span class="text-link">
            <span data-en="Explore" data-ar="استكشف">Explore</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

      <a href={`${base}collections/gold`} class="collection-card reveal">
        <div class="collection-card-img">
          <img
            src={gold}
            alt="Gold Collection — 18-karat white and yellow gold jewelry"
            width="800"
            height="960"
            loading="lazy"
          />
          <div class="collection-card-overlay"></div>
        </div>
        <div class="collection-card-body">
          <h3 data-en="Gold Collection" data-ar="مجموعة الذهب">Gold Collection</h3>
          <p data-en="18-karat white and yellow gold — one of the widest ranges in Amman, at competitive prices."
             data-ar="ذهب أبيض وأصفر عيار 18 — من أوسع التشكيلات في عمّان، بأسعار تنافسية.">
            18-karat white and yellow gold — one of the widest ranges
            in Amman, at competitive prices.
          </p>
          <span class="text-link">
            <span data-en="Explore" data-ar="استكشف">Explore</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" aria-label="Services">
    <div class="container">
      <div class="services-heading reveal">
        <span class="section-eyebrow" data-en="What We Offer" data-ar="ما نقدمه">What We Offer</span>
        <h2 class="section-title" data-en="Beyond the Collection" data-ar="أكثر من مجرد مجموعة">Beyond the Collection</h2>
      </div>
      <div class="services-grid">

        <div class="service-item reveal">
          <div class="service-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 22 22 7 12 2"/><line x1="2" y1="7" x2="22" y2="7"/></svg>
          </div>
          <h3 data-en="Diamond Jewelry" data-ar="مجوهرات الألماس">Diamond Jewelry</h3>
          <p data-en="A wide range of certified, guaranteed fine Belgian diamond jewelry."
             data-ar="تشكيلة واسعة من مجوهرات الألماس البلجيكي الراقية المعتمدة والمضمونة.">A wide range of certified, guaranteed fine Belgian diamond jewelry.</p>
        </div>

        <div class="service-item reveal">
          <div class="service-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3 data-en="Gold Jewelry" data-ar="مجوهرات الذهب">Gold Jewelry</h3>
          <p data-en="18-karat white and yellow gold — rings, earrings, bracelets, and necklaces."
             data-ar="ذهب أبيض وأصفر عيار 18 — خواتم وأقراط وأساور وقلائد.">18-karat white and yellow gold — rings, earrings, bracelets, and necklaces.</p>
        </div>

        <div class="service-item reveal">
          <div class="service-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3 data-en="Repair &amp; Maintenance" data-ar="إصلاح وصيانة">Repair &amp; Maintenance</h3>
          <p data-en="High-standard, prompt repair service for any piece in your collection."
             data-ar="خدمة إصلاح عالية الجودة وسريعة لأي قطعة في مجموعتك.">High-standard, prompt repair service for any piece in your collection.</p>
        </div>

        <div class="service-item reveal">
          <div class="service-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3 data-en="Appraisals &amp; Consultancy" data-ar="التقييم والاستشارة">Appraisals &amp; Consultancy</h3>
          <p data-en="Free, impartial valuation of diamonds, gold, and watches."
             data-ar="تقييم مجاني ومحايد للألماس والذهب والساعات.">Free, impartial valuation of diamonds, gold, and watches.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="testimonial" aria-label="Customer testimonial">
    <div class="container">
      <figure class="testimonial-figure reveal">
        <span class="testimonial-mark" aria-hidden="true">"</span>
        <blockquote>
          <p data-en="Samir Akkawi Jewelry is one of the best jewelry shops in Amman — unique yet classic pieces that truly last a lifetime."
             data-ar="محلات سمير عكاوي للمجوهرات من أفضل محلات المجوهرات في عمّان — قطع فريدة وكلاسيكية في آنٍ واحد، تدوم حقاً مدى الحياة.">
            Samir Akkawi Jewelry is one of the best jewelry shops in Amman —
            unique yet classic pieces that truly last a lifetime.
          </p>
        </blockquote>
        <figcaption data-en="S.N. — Amman, Jordan" data-ar="س. ن. — عمّان، الأردن">S.N. &mdash; Amman, Jordan</figcaption>
      </figure>
    </div>
  </section>

  <!-- CONTACT STRIP -->
  <section class="contact-strip" aria-label="Contact information">
    <div class="contact-strip-inner container">

      <div class="contact-strip-text reveal">
        <span class="section-eyebrow" data-en="Come See Us" data-ar="زورونا">Come See Us</span>
        <h2 class="section-title" style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
          data-en="Every piece deserves a personal touch."
          data-ar="كل قطعة تستحق لمسة شخصية.">
          Every piece deserves<br /><em>a personal touch.</em>
        </h2>
        <a href={`${base}contact`} class="btn btn-primary">
          <span data-en="Get in Touch" data-ar="تواصل معنا">Get in Touch</span>
        </a>
      </div>

      <div class="contact-strip-details reveal">
        <div class="contact-detail">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <p data-en="9 Shatt Al-Arab Street" data-ar="شارع شط العرب ٩">9 Shatt Al-Arab Street</p>
            <p data-en="Um Uthaina, Amman, Jordan" data-ar="أم أذينة، عمّان، الأردن">Um Uthaina, Amman, Jordan</p>
          </div>
        </div>
        <div class="contact-detail">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.92a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.9z"/></svg>
          <a href="https://wa.me/962795800651" target="_blank" rel="noopener noreferrer">+962 795 800 651</a>
        </div>
        <div class="contact-detail">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:samir@akkawijewelry.com">samir@akkawijewelry.com</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ───────────────────────────────────────────────── */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
}

.hero-text {
  background: var(--color-bg);
  display: flex;
  align-items: center;
  padding: calc(var(--nav-height) + var(--space-7)) var(--space-7) var(--space-7);
}

.hero-text-inner { max-width: 520px; }

.hero-title {
  font-size: clamp(2.6rem, 4.5vw, 4.5rem);
  font-weight: 300;
  line-height: 1.08;
  color: var(--color-text);
  margin-bottom: var(--space-4);
}

.hero-title em {
  font-style: italic;
  color: var(--color-gold-dark);
}

.hero-sub {
  color: var(--color-text-muted);
  font-size: 1rem;
  line-height: 1.75;
  margin-bottom: var(--space-5);
  max-width: 440px;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

.hero-image {
  overflow: hidden;
  position: relative;
}

.hero-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* ── Shared text-link ───────────────────────────────────── */
.text-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-sans);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-gold-dark);
  transition: gap var(--transition-fast);
}

.text-link:hover { gap: var(--space-3); }

/* ── Brand Story ────────────────────────────────────────── */
.story {
  padding: var(--space-8) 0;
  background: var(--color-surface);
}

.story-inner {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: var(--space-7);
  align-items: center;
}

.story-image {
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: 0 8px 40px rgba(28, 25, 23, 0.1);
}

.story-image img {
  width: 100%;
  height: auto;
  display: block;
}

.story-text p {
  color: var(--color-text-muted);
  margin-bottom: var(--space-4);
  max-width: 480px;
}

/* ── Collections ────────────────────────────────────────── */
.collections-preview {
  padding: var(--space-8) 0 0;
  background: var(--color-bg);
}

.collections-heading { margin-bottom: var(--space-6); }

.collections-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-top: var(--space-5);
}

.collection-card {
  display: block;
  overflow: hidden;
  cursor: pointer;
}

.collection-card-img {
  position: relative;
  overflow: hidden;
  aspect-ratio: 4/5;
}

.collection-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 700ms ease-out;
}

.collection-card:hover .collection-card-img img {
  transform: scale(1.04);
}

.collection-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(28, 25, 23, 0.3) 0%, transparent 50%);
  pointer-events: none;
}

.collection-card-body {
  padding: var(--space-5) var(--space-5) var(--space-6);
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}

.collection-card-body h3 {
  font-size: 1.5rem;
  margin-bottom: var(--space-3);
}

.collection-card-body p {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  margin-bottom: var(--space-4);
  max-width: none;
}

/* ── Services ───────────────────────────────────────────── */
.services {
  padding: var(--space-8) 0;
  background: var(--color-bg);
}

.services-heading { margin-bottom: var(--space-6); }

.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-4);
}

.service-item {
  padding: var(--space-5);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  transition: border-color var(--transition-base), box-shadow var(--transition-base);
}

.service-item:hover {
  border-color: var(--color-gold);
  box-shadow: 0 4px 20px rgba(201, 168, 76, 0.1);
}

.service-icon {
  color: var(--color-gold);
  margin-bottom: var(--space-4);
}

.service-item h3 {
  font-size: 1.05rem;
  margin-bottom: var(--space-3);
}

.service-item p {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  max-width: none;
}

/* ── Testimonial ────────────────────────────────────────── */
.testimonial {
  padding: var(--space-8) 0;
  background: var(--color-surface-2);
}

.testimonial-figure {
  max-width: 640px;
  margin: 0 auto;
  text-align: center;
}

.testimonial-mark {
  display: block;
  font-family: var(--font-serif);
  font-size: 6rem;
  line-height: 0.6;
  color: var(--color-gold);
  margin-bottom: var(--space-5);
  opacity: 0.5;
}

.testimonial-figure blockquote p {
  font-family: var(--font-serif);
  font-size: clamp(1.2rem, 2.5vw, 1.6rem);
  font-style: italic;
  font-weight: 300;
  color: var(--color-text);
  line-height: 1.55;
  margin: 0 auto var(--space-5);
  max-width: none;
}

.testimonial-figure figcaption {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

/* ── Contact strip ──────────────────────────────────────── */
.contact-strip {
  padding: var(--space-8) 0;
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}

.contact-strip-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-7);
  align-items: center;
}

.contact-strip-text .section-title em { color: var(--color-gold-dark); }
.contact-strip-text .section-title { margin-bottom: var(--space-5); }

.contact-strip-details {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.contact-detail {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
}

.contact-detail svg { flex-shrink: 0; margin-top: 2px; color: var(--color-gold); }
.contact-detail p,
.contact-detail a {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  max-width: none;
}
.contact-detail a { transition: color var(--transition-fast); }
.contact-detail a:hover { color: var(--color-gold-dark); }

/* ── Responsive ─────────────────────────────────────────── */
@media (max-width: 1024px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
  .story-inner { grid-template-columns: 1fr; }
  .story-image { max-width: 480px; }
}

