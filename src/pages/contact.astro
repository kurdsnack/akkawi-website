---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Visit Samir Akkawi Jewelry in Um Uthaina, Amman. Call, WhatsApp, or send us a message.">

  <section class="page-header">
    <div class="container">
      <span class="section-eyebrow" data-en="We'd Love to Hear From You" data-ar="يسعدنا التواصل معكم">We'd Love to Hear From You</span>
      <h1 class="section-title" style="font-size: clamp(2.4rem, 5vw, 4rem);" data-en="Get in Touch" data-ar="تواصل معنا">Get in Touch</h1>
      <p class="section-subtitle" data-en="Come visit us in Amman, call, or send a message below. No appointment needed." data-ar="زورونا في عمّان، أو اتصلوا بنا، أو أرسلوا رسالة أدناه. لا حاجة لحجز موعد.">
        Come visit us in Amman, call, or send a message below. No appointment needed.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="contact-inner container">

      <!-- Contact form (mailto) -->
      <div class="contact-form-wrap reveal">
        <h2 data-en="Send a Message" data-ar="أرسل رسالة">Send a Message</h2>
        <p class="form-note" data-en='Clicking "Send Message" will open your email client with this form pre-filled.' data-ar='سيفتح زر الإرسال برنامج البريد الإلكتروني مع تفاصيل الرسالة.'>Clicking "Send Message" will open your email client with this form pre-filled.</p>
        <form class="contact-form" id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name" data-en="Full Name" data-ar="الاسم الكامل">Full Name</label>
              <input type="text" id="name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="phone" data-en="Phone" data-ar="الهاتف">Phone</label>
              <input type="tel" id="phone" name="phone" placeholder="+962 7XX XXX XXX" />
            </div>
          </div>
          <div class="form-group">
            <label for="email" data-en="Email Address" data-ar="البريد الإلكتروني">Email Address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>
          <div class="form-group">
            <label for="subject" data-en="Subject" data-ar="الموضوع">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="e.g. Diamond ring inquiry" />
          </div>
          <div class="form-group">
            <label for="message" data-en="Message" data-ar="الرسالة">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us what you're looking for..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">
            <span data-en="Send Message" data-ar="إرسال">Send Message</span>
          </button>
        </form>
      </div>

      <!-- Contact details -->
      <div class="contact-details reveal">
        <h2 data-en="Find Us" data-ar="موقعنا">Find Us</h2>
        <div class="contact-details-list">
          <div class="contact-detail-item">
            <div class="contact-detail-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="detail-label" data-en="Address" data-ar="العنوان">Address</p>
              <p><span data-en="9 Shatt Al-Arab Street" data-ar="شارع شط العرب ٩">9 Shatt Al-Arab Street</span><br /><span data-en="Um Uthaina, Amman, Jordan" data-ar="أم أذينة، عمّان، الأردن">Um Uthaina, Amman, Jordan</span></p>
            </div>
          </div>
          <div class="contact-detail-item">
            <div class="contact-detail-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.92a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.9z"/></svg>
            </div>
            <div>
              <p class="detail-label" data-en="Phone / WhatsApp" data-ar="الهاتف / واتساب">Phone / WhatsApp</p>
              <a href="https://wa.me/962795800651" target="_blank" rel="noopener noreferrer">+962 795 800 651</a>
            </div>
          </div>
          <div class="contact-detail-item">
            <div class="contact-detail-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="detail-label" data-en="Email" data-ar="البريد الإلكتروني">Email</p>
              <a href="mailto:samir@akkawijewelry.com">samir@akkawijewelry.com</a>
            </div>
          </div>
          <div class="contact-detail-item">
            <div class="contact-detail-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </div>
            <div>
              <p class="detail-label" data-en="Instagram" data-ar="إنستغرام">Instagram</p>
              <a href="https://instagram.com/akkawi_jewelry" target="_blank" rel="noopener noreferrer">@akkawi_jewelry</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Google Maps embed -->
  <section class="contact-map">
    <div class="map-header container">
      <h2 data-en="Our Location" data-ar="موقعنا على الخريطة">Our Location</h2>
      <a
        href="https://maps.app.goo.gl/f4gkQEhwfBJR4B7H6"
        target="_blank"
        rel="noopener noreferrer"
        class="map-open-link"
      >
        <span data-en="Open in Google Maps" data-ar="افتح في خرائط جوجل">Open in Google Maps</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
    <div class="map-frame">
      <iframe
        src="https://maps.google.com/maps?q=9+Shatt+Al-Arab+Street,+Um+Uthaina,+Amman,+Jordan&output=embed&hl=en"
        width="100%"
        height="480"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Samir Akkawi Jewelry — Um Uthaina, Amman"
      ></iframe>
    </div>
  </section>

</BaseLayout>

<style>
.page-header {
  padding: var(--space-7) 0 var(--space-6);
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
}

.contact-body { padding: var(--space-7) 0; background: var(--color-surface); }

.contact-inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: var(--space-7);
  align-items: start;
}

/* Form */
.contact-form-wrap h2 { font-size: 1.5rem; margin-bottom: var(--space-2); }
.form-note { font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: var(--space-5); max-width: none; }
.contact-form { display: flex; flex-direction: column; gap: var(--space-4); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
.form-group { display: flex; flex-direction: column; gap: var(--space-2); }
.form-group label {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}
.form-group input,
.form-group textarea {
  font-family: var(--font-sans);
  font-size: 0.95rem;
  color: var(--color-text);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 12px var(--space-3);
  transition: border-color var(--transition-fast);
  outline: none;
  resize: vertical;
}
.form-group input::placeholder,
.form-group textarea::placeholder { color: var(--color-text-light); }
.form-group input:focus,
.form-group textarea:focus { border-color: var(--color-gold); }
.contact-form .btn { align-self: flex-start; }

/* Details */
.contact-details h2 { font-size: 1.5rem; margin-bottom: var(--space-5); }
.contact-details-list { display: flex; flex-direction: column; gap: var(--space-5); }
.contact-detail-item { display: flex; align-items: flex-start; gap: var(--space-3); }
.contact-detail-icon {
  width: 36px; height: 36px;
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  color: var(--color-gold);
}
.detail-label {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-light);
  margin-bottom: 4px;
  max-width: none;
}
.contact-detail-item p:last-child,
.contact-detail-item a {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  max-width: none;
}
.contact-detail-item a { transition: color var(--transition-fast); }
.contact-detail-item a:hover { color: var(--color-gold-dark); }

/* Map */
.contact-map {
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.map-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--space-6);
  padding-bottom: var(--space-4);
  gap: var(--space-4);
}

.map-header h2 {
  font-size: 1.4rem;
  margin: 0;
}

.map-open-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-sans);
  font-size: 0.8rem;
  font-weight: 400;
  letter-spacing: 0.08em;
  color: var(--color-gold-dark);
  transition: color var(--transition-fast);
  white-space: nowrap;
}
.map-open-link:hover { color: var(--color-text); }

.map-frame {
  width: 100%;
  line-height: 0;
}

.map-frame iframe {
  width: 100%;
  display: block;
}

@media (max-width: 768px) {
  .contact-inner { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .map-header { flex-direction: column; align-items: flex-start; }
  .map-frame iframe { height: 320px; }
}
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name    = (form.querySelector('#name') as HTMLInputElement).value;
    const email   = (form.querySelector('#email') as HTMLInputElement).value;
    const subject = (form.querySelector('#subject') as HTMLInputElement).value || 'Website Inquiry';
    const phone   = (form.querySelector('#phone') as HTMLInputElement).value;
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value;
    const body    = `Name: ${name}\nPhone: ${phone}\nEmail: ${email}\n\n${message}`;
    window.location.href = `mailto:samir@akkawijewelry.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>
