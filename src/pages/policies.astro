---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="Store Policies" description="Exchange, return, and warranty policies at Samir Akkawi Jewelry — Amman, Jordan.">

  <section class="page-header">
    <div class="container">
      <span class="section-eyebrow" data-en="Transparency &amp; Trust" data-ar="الشفافية والثقة">Transparency &amp; Trust</span>
      <h1 class="section-title" style="font-size: clamp(2.4rem, 5vw, 4rem);"
        data-en="Store Policies" data-ar="سياسات المتجر">Store Policies</h1>
      <p class="section-subtitle"
        data-en="We believe that clear, fair policies are part of what makes a jewelry relationship last. Read on to understand exactly what we offer."
        data-ar="نؤمن بأن السياسات الواضحة والعادلة جزء من ما يجعل علاقة المجوهرات تدوم. اقرأ لتفهم بالضبط ما نقدمه.">
        We believe that clear, fair policies are part of what makes a jewelry relationship last. Read on to understand exactly what we offer.
      </p>
    </div>
  </section>

  <section class="policies-body">
    <div class="container">

      <div class="policy-block reveal">
        <div class="policy-block-header">
          <div class="value-rule"></div>
          <h2 data-en="Exchange &amp; Returns — Diamond Jewelry" data-ar="الاستبدال والإرجاع — مجوهرات الألماس">Exchange &amp; Returns — Diamond Jewelry</h2>
        </div>
        <div class="policy-grid">
          <div class="policy-card">
            <h3 data-en="Within 30 Days" data-ar="خلال 30 يوماً">Within 30 Days</h3>
            <p data-en="Free return or exchange on any diamond jewelry purchase, no questions asked."
               data-ar="إرجاع أو استبدال مجاني لأي مشتريات مجوهرات الألماس، دون أسئلة.">Free return or exchange on any diamond jewelry purchase, no questions asked.</p>
          </div>
          <div class="policy-card">
            <h3 data-en="After 30 Days — Returns" data-ar="بعد 30 يوماً — الإرجاع">After 30 Days — Returns</h3>
            <p data-en="Returns are accepted subject to a 30% fee on the original purchase price."
               data-ar="يُقبل الإرجاع مع خصم 30% من سعر الشراء الأصلي.">Returns are accepted subject to a 30% fee on the original purchase price.</p>
          </div>
          <div class="policy-card">
            <h3 data-en="After 30 Days — Exchanges" data-ar="بعد 30 يوماً — الاستبدال">After 30 Days — Exchanges</h3>
            <p data-en="Exchanges are accepted subject to a 15% fee on the original purchase price."
               data-ar="يُقبل الاستبدال مع خصم 15% من سعر الشراء الأصلي.">Exchanges are accepted subject to a 15% fee on the original purchase price.</p>
          </div>
        </div>
      </div>

      <div class="policy-block reveal">
        <div class="policy-block-header">
          <div class="value-rule"></div>
          <h2 data-en="Exchange &amp; Returns — Gold Jewelry" data-ar="الاستبدال والإرجاع — مجوهرات الذهب">Exchange &amp; Returns — Gold Jewelry</h2>
        </div>
        <div class="policy-grid">
          <div class="policy-card">
            <h3 data-en="Market Price Return" data-ar="الإرجاع بسعر السوق">Market Price Return</h3>
            <p data-en="Gold jewelry is returned at the prevailing international market gold price on the date of exchange — not the original purchase price."
               data-ar="تُرجَع مجوهرات الذهب بسعر الذهب الدولي السائد في تاريخ الاستبدال — لا بسعر الشراء الأصلي.">Gold jewelry is returned at the prevailing international market gold price on the date of exchange — not the original purchase price.</p>
          </div>
          <div class="policy-card">
            <h3 data-en="Deductions Apply" data-ar="خصومات مطبقة">Deductions Apply</h3>
            <p data-en="Manufacturing costs, stone weights, and non-gold components are deducted from the return value. We will calculate this transparently for you."
               data-ar="تُخصم تكاليف الصناعة وأوزان الأحجار والمكونات غير الذهبية من قيمة الإرجاع. سنحسب ذلك لك بشفافية.">Manufacturing costs, stone weights, and non-gold components are deducted from the return value. We will calculate this transparently for you.</p>
          </div>
        </div>
      </div>

      <div class="policy-block reveal">
        <div class="policy-block-header">
          <div class="value-rule"></div>
          <h2 data-en="Warranty" data-ar="الضمان">Warranty</h2>
        </div>
        <div class="policy-grid">
          <div class="policy-card">
            <h3 data-en="Price Guarantee" data-ar="ضمان السعر">Price Guarantee</h3>
            <p data-en="All jewelry is priced at international market value at the time of purchase. We guarantee the pricing is fair and current."
               data-ar="جميع المجوهرات مسعّرة بالقيمة السوقية الدولية وقت الشراء. نضمن أن التسعير عادل وحديث.">All jewelry is priced at international market value at the time of purchase. We guarantee the pricing is fair and current.</p>
          </div>
          <div class="policy-card">
            <h3 data-en="Lifetime Care" data-ar="عناية مدى الحياة">Lifetime Care</h3>
            <p data-en="Complimentary polishing, servicing, and technical inspection for any piece purchased from us — at any time, for as long as you own it."
               data-ar="تلميع وخدمة وفحص فني مجاني لأي قطعة اشتريتها منا — في أي وقت، طالما تمتلكها.">Complimentary polishing, servicing, and technical inspection for any piece purchased from us — at any time, for as long as you own it.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section class="policies-cta">
    <div class="container">
      <div class="policies-cta-inner reveal">
        <p data-en="Have a question about a specific situation? Come in or send us a message — we are always happy to clarify."
           data-ar="هل لديك سؤال حول حالة معينة؟ تفضل بالزيارة أو أرسل لنا رسالة — يسعدنا التوضيح دائماً.">Have a question about a specific situation? Come in or send us a message — we are always happy to clarify.</p>
        <a href={`${base}contact`} class="btn btn-primary">
          <span data-en="Contact Us" data-ar="تواصل معنا">Contact Us</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-header {
  padding: var(--space-7) 0 var(--space-6);
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
}

.policies-body { padding: var(--space-7) 0; background: var(--color-surface); }

.policy-block {
  padding: var(--space-6) 0;
  border-bottom: 1px solid var(--color-border);
}
.policy-block:last-child { border-bottom: none; }
.policy-block-header { margin-bottom: var(--space-5); }
.value-rule { width: 32px; height: 2px; background: var(--color-gold); margin-bottom: var(--space-4); }
.policy-block h2 { font-size: 1.7rem; }

.policy-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4);
}

.policy-card {
  padding: var(--space-5);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}
.policy-card h3 { font-size: 1rem; margin-bottom: var(--space-3); }
.policy-card p { font-size: 0.875rem; color: var(--color-text-muted); max-width: none; }

.policies-cta {
  padding: var(--space-6) 0;
  background: var(--color-surface-2);
  border-top: 1px solid var(--color-border);
}
.policies-cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-5);
}
.policies-cta-inner p {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  max-width: 560px;
}

@media (max-width: 768px) {
  .policy-grid { grid-template-columns: 1fr; }
  .policies-cta-inner { justify-content: flex-start; }
}
</style>
