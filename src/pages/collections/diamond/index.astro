---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const categories = [
  { label: 'Rings',          href: '/collections/diamond/rings',    img: 'photo-1605100804763-247f67b3557e' },
  { label: 'Necklaces',      href: '/collections/diamond/necklaces', img: 'photo-1611652022419-a9419f74343d' },
  { label: 'Bracelets',      href: '/collections/diamond/bracelets', img: 'photo-1573408301185-9519b33b77c7' },
  { label: 'Solitaire Rings',href: '/collections/diamond/solitaire', img: 'photo-1515562141207-7a88fb7ce338' },
  { label: 'Earrings',       href: '/collections/diamond/earrings',  img: 'photo-1589128777073-263566ae5e4d' },
  { label: 'Pendants',       href: '/collections/diamond/pendants',  img: 'photo-1506630448388-4e683c67ddb0' },
];

const base = 'https://images.unsplash.com/';
const params = '?auto=format&fit=crop&w=600&q=80';
---

<BaseLayout title="Diamond Collection" description="Diamond rings, necklaces, bracelets, solitaires, earrings and pendants at Samir Akkawi Jewelry.">

  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/collections">Collections</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Diamond</span>
      </nav>
      <span class="section-eyebrow">Certified Belgian Diamonds</span>
      <h1 class="section-title" style="font-size: clamp(2.4rem, 5vw, 4rem);">Diamond Collection</h1>
      <p class="section-subtitle">Fine diamond jewelry in white and yellow gold — certified, guaranteed, and crafted to last.</p>
    </div>
  </section>

  <section class="category-grid-section">
    <div class="container">
      <div class="category-grid">
        {categories.map(cat => (
          <a href={cat.href} class="category-card reveal">
            <div class="category-card-img">
              <img src={`${base}${cat.img}${params}`} alt={cat.label} width="600" height="600" loading="lazy" />
            </div>
            <div class="category-card-body">
              <h3>{cat.label}</h3>
              <span class="text-link">Browse <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-header { padding: var(--space-7) 0 var(--space-6); background: var(--color-bg); border-bottom: 1px solid var(--color-border); }
.breadcrumb { display: flex; align-items: center; gap: var(--space-2); font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: var(--space-4); }
.breadcrumb a { transition: color var(--transition-fast); }
.breadcrumb a:hover { color: var(--color-gold-dark); }

.category-grid-section { padding: var(--space-7) 0; background: var(--color-surface); }
.category-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }

.category-card { display: block; overflow: hidden; border-radius: var(--radius-md); border: 1px solid var(--color-border); transition: box-shadow var(--transition-base); }
.category-card:hover { box-shadow: 0 8px 32px rgba(28,25,23,0.1); }
.category-card-img { overflow: hidden; aspect-ratio: 1; }
.category-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 600ms ease-out; }
.category-card:hover .category-card-img img { transform: scale(1.05); }
.category-card-body { padding: var(--space-4); background: var(--color-surface); display: flex; align-items: center; justify-content: space-between; }
.category-card-body h3 { font-size: 1.05rem; }
.text-link { display: inline-flex; align-items: center; gap: var(--space-1); font-family: var(--font-sans); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold-dark); transition: gap var(--transition-fast); }
.category-card:hover .text-link { gap: var(--space-2); }

@media (max-width: 768px) { .category-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .category-grid { grid-template-columns: 1fr; } }
</style>
