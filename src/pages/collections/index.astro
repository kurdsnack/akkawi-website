---
import BaseLayout from '../../layouts/BaseLayout.astro';
const diamond = 'https://images.unsplash.com/photo-1573408301185-9519b33b77c7?auto=format&fit=crop&w=900&q=80';
const gold    = 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?auto=format&fit=crop&w=900&q=80';
---

<BaseLayout title="Collections" description="Browse the Diamond and Gold jewelry collections at Samir Akkawi Jewelry, Amman.">

  <section class="page-header">
    <div class="container">
      <span class="section-eyebrow" data-en="Explore" data-ar="استكشف">Explore</span>
      <h1 class="section-title" style="font-size: clamp(2.4rem, 5vw, 4rem);"
        data-en="Our Collections" data-ar="مجموعاتنا">Our Collections</h1>
      <p class="section-subtitle"
        data-en="Certified Belgian diamonds and 18-karat gold — two collections, one commitment to quality."
        data-ar="الألماس البلجيكي المعتمد والذهب عيار 18 — مجموعتان، والتزام واحد بالجودة.">
        Certified Belgian diamonds and 18-karat gold — two collections, one commitment to quality.
      </p>
    </div>
  </section>

  <div class="collections-split">

    <a href="/collections/diamond" class="split-card">
      <div class="split-card-img">
        <img src={diamond} alt="Diamond Collection" width="900" height="1100" loading="eager" />
        <div class="split-card-overlay"></div>
      </div>
      <div class="split-card-body">
        <span class="section-eyebrow" data-en="Fine Diamonds" data-ar="الألماس الراقي">Fine Diamonds</span>
        <h2 data-en="Diamond Collection" data-ar="مجموعة الماس">Diamond Collection</h2>
        <p data-en="Rings, necklaces, bracelets, solitaires, earrings, and pendants — all in certified Belgian diamonds."
           data-ar="خواتم وقلائد وأساور وسوليتير وأقراط وقلادات — كلها بالألماس البلجيكي المعتمد.">Rings, necklaces, bracelets, solitaires, earrings, and pendants — all in certified Belgian diamonds.</p>
        <span class="text-link">
          <span data-en="Explore collection" data-ar="استكشف المجموعة">Explore collection</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </div>
    </a>

    <a href="/collections/gold" class="split-card">
      <div class="split-card-img">
        <img src={gold} alt="Gold Collection" width="900" height="1100" loading="eager" />
        <div class="split-card-overlay"></div>
      </div>
      <div class="split-card-body">
        <span class="section-eyebrow" data-en="18-Karat Gold" data-ar="ذهب عيار 18">18-Karat Gold</span>
        <h2 data-en="Gold Collection" data-ar="مجموعة الذهب">Gold Collection</h2>
        <p data-en="One of the widest selections of white and yellow gold jewelry in Amman — at market prices."
           data-ar="من أوسع تشكيلات مجوهرات الذهب الأبيض والأصفر في عمّان — بأسعار السوق.">One of the widest selections of white and yellow gold jewelry in Amman — at market prices.</p>
        <span class="text-link">
          <span data-en="Explore collection" data-ar="استكشف المجموعة">Explore collection</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </div>
    </a>

  </div>

</BaseLayout>

<style>
.page-header { padding: var(--space-7) 0 var(--space-6); background: var(--color-bg); border-bottom: 1px solid var(--color-border); }
.collections-split { display: grid; grid-template-columns: 1fr 1fr; }

.split-card { display: block; overflow: hidden; cursor: pointer; }
.split-card-img { position: relative; overflow: hidden; aspect-ratio: 4/5; }
.split-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 700ms ease-out; }
.split-card:hover .split-card-img img { transform: scale(1.04); }
.split-card-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(28,25,23,0.35) 0%, transparent 50%);
  pointer-events: none;
}
.split-card-body {
  padding: var(--space-6);
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}
.split-card-body h2 { font-size: 1.8rem; margin: var(--space-2) 0 var(--space-3); }
.split-card-body p { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: var(--space-4); max-width: none; }

.text-link { display: inline-flex; align-items: center; gap: var(--space-2); font-family: var(--font-sans); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-gold-dark); transition: gap var(--transition-fast); }
.text-link:hover, .split-card:hover .text-link { gap: var(--space-3); }

@media (max-width: 768px) { .collections-split { grid-template-columns: 1fr; } }
</style>
