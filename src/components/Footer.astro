---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner container">

    <div class="footer-brand">
      <a href="/" aria-label="Samir Akkawi Jewelry — Home">
        <div class="footer-logo-badge">
          <img
            src="/assets/images/brand/akkawi-logo-3.jpg"
            alt="Akkawi Jewelry logo"
            width="56"
            height="56"
            loading="lazy"
          />
        </div>
      </a>
      <p class="footer-tagline" data-en="Fine gold & diamond jewelry since the early 1990s." data-ar="مجوهرات الذهب والألماس الراقية منذ مطلع التسعينيات.">Fine gold &amp; diamond jewelry<br />since the early 1990s.</p>
      <div class="footer-socials">
        <a
          href="https://www.facebook.com/akkawijewelry"
          aria-label="Akkawi Jewelry on Facebook"
          target="_blank"
          rel="noopener noreferrer"
        >
          <!-- Facebook -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/akkawi_jewelry"
          aria-label="Akkawi Jewelry on Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <!-- Instagram -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      </div>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <p class="footer-nav-heading" data-en="Navigate" data-ar="تصفح">Navigate</p>
      <ul>
        <li><a href="/"><span data-en="Home" data-ar="الرئيسية">Home</span></a></li>
        <li><a href="/collections"><span data-en="Collections" data-ar="المجموعات">Collections</span></a></li>
        <li><a href="/about"><span data-en="About" data-ar="من نحن">About</span></a></li>
        <li><a href="/services"><span data-en="Services" data-ar="خدماتنا">Services</span></a></li>
        <li><a href="/policies"><span data-en="Policies" data-ar="السياسات">Policies</span></a></li>
        <li><a href="/contact"><span data-en="Contact" data-ar="تواصل معنا">Contact</span></a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <p class="footer-nav-heading" data-en="Visit Us" data-ar="زورونا">Visit Us</p>
      <address>
        <p data-en="9 Shatt Al-Arab Street" data-ar="شارع شط العرب ٩">9 Shatt Al-Arab Street</p>
        <p data-en="Um Uthaina, Amman, Jordan" data-ar="أم أذينة، عمّان، الأردن">Um Uthaina, Amman, Jordan</p>
      </address>
      <a
        href="https://wa.me/962795800651"
        class="footer-contact-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp +962 795 800 651"
      >
        +962 795 800 651
      </a>
      <a
        href="mailto:samir@akkawijewelry.com"
        class="footer-contact-link"
      >
        samir@akkawijewelry.com
      </a>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {year} Samir Akkawi Jewelry. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--color-surface-2);
  border-top: 1px solid var(--color-border);
  margin-top: var(--space-8);
}

.footer-inner {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1.4fr;
  gap: var(--space-7);
  padding-top: var(--space-7);
  padding-bottom: var(--space-7);
}

/* ── Brand column ───────────────────────────────────────── */
.footer-logo-badge {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-white);
  margin-bottom: var(--space-3);
}

.footer-logo-badge img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.footer-tagline {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-bottom: var(--space-4);
  max-width: none;
}

.footer-socials {
  display: flex;
  gap: var(--space-3);
}

.footer-socials a {
  color: var(--color-text-muted);
  transition: color var(--transition-fast);
  display: flex;
  align-items: center;
}

.footer-socials a:hover {
  color: var(--color-gold);
}

/* ── Nav column ─────────────────────────────────────────── */
.footer-nav-heading {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-gold-dark);
  margin-bottom: var(--space-4);
  max-width: none;
}

.footer-nav ul {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer-nav a {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  transition: color var(--transition-fast);
}

.footer-nav a:hover {
  color: var(--color-text);
}

/* ── Contact column ─────────────────────────────────────── */
.footer-contact {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer-contact address {
  font-style: normal;
}

.footer-contact address p,
.footer-contact-link {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  max-width: none;
}

.footer-contact-link {
  transition: color var(--transition-fast);
  display: block;
}

.footer-contact-link:hover {
  color: var(--color-gold);
}

/* ── Bottom bar ─────────────────────────────────────────── */
.footer-bottom {
  border-top: 1px solid var(--color-border);
  padding: var(--space-4) 0;
}

.footer-bottom p {
  font-size: 0.75rem;
  color: var(--color-text-muted);
  max-width: none;
}

/* ── Mobile ─────────────────────────────────────────────── */
@media (max-width: 768px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }
}
</style>
